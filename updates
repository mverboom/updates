#!/usr/bin/env bash
#
# Upgrade systems and create report
#

inc=( "$( dirname "$( realpath "$0")" )" "$( dirname "$( type -p "$0")" )" "$(dirname "$0")" )
for lib in libfrmt.sh libwiki.sh libupdates.sh; do
   found=0
   for libinc in "${inc[@]}"; do
      [[ -e "$libinc/$lib" ]] && { source "$libinc/$lib"; found=1; break; }
   done
   test "$found" -eq 0 && { printf '%s\n' "Library $lib not found."; exit 1; }
done

# Track mktemp files so they are removed on any exit path.
TMPFILES=()
tmpfile() { local f; f="$(mktemp)"; TMPFILES+=( "$f" ); printf '%s' "$f"; }
trap 'rm -f "${TMPFILES[@]}" 2>/dev/null' EXIT

# Return 0 if $1 equals any of the remaining arguments. Replaces the error-prone
# `[[ " ${arr[@]} " =~ " $val " ]]` membership idiom.
in_array() {
   local needle="$1" e
   shift
   for e in "$@"; do
      [[ $e == "$needle" ]] && return 0
   done
   return 1
}

makesection() {
   local render="$1"; shift
   local cache="$1"; shift
   local title="$1"; shift
   local sectionreport host hostrender cts ct ctcount ctreport

   sectionreport=$(tmpfile)

   for host in "$@"; do
      hostrender=0
      if [[ -f "$cache/$host/$host" ]]; then
         $render "$cache/$host/$host" >> "$sectionreport" && hostrender=1
      fi

      unset cts
      cts=()
      for f in "$cache/$host/"*; do
         [[ -e "$f" ]] || continue
         f=${f##*/}
         [[ "$f" != "$host" ]] && cts+=( "$f" )
      done

      if test "${#cts[*]}" -gt 0; then
         ctreport=$(tmpfile)
         ctcount=0
         for ct in "${cts[@]}"; do
            if [[ -e "$cache/$host/$ct" ]]; then
               $render "$cache/$host/$ct" >> "$ctreport" && ctcount=$(( ctcount + 1 ))
            fi
         done
         if test "$ctcount" -gt 0; then
            if [[ "$hostrender" == "0" ]] ; then
               frmt new hostreport "${outputformat}" -b
               hostreport h2 "$host" >> "$sectionreport"
               hostreport del
            fi
            frmt new frmtreport "${outputformat}" -b
            frmtreport foldstart "${ctcount} containers" >> "$sectionreport"
            cat "$ctreport" >> "$sectionreport"
            frmtreport foldend >> "$sectionreport"
            frmtreport del
         fi
         rm -f "$ctreport"
      fi
   done

   if [[ -s "$sectionreport" ]]; then
      frmt new frmtreport "${outputformat}" -b
      frmtreport h1 "$title"
      frmtreport del
      cat "$sectionreport"
   fi
   rm -f "$sectionreport"
}

verifycache() {
   local cache="$1"
   local host="$2"
   local ct="$3"
   local dst

   [[ -d "$cache/$host" ]] || mkdir -p "$cache/$host"

   dst="$cache/$host/$host"
   [[ "$ct" != "" ]] && dst="$cache/$host/$ct"
   test "$FORCE" -eq 1 && return 0
   if [[ -e "$dst" ]]; then
      lastmod=$(stat -c "%Y" "$dst")
      test $(( $(date "+%s") - lastmod )) -lt $MAXCACHEAGE && return 1
   fi
   return 0
}

# Wait for one background job in the caller's `running` array to finish and
# free its slot. Sets $slot to the freed index. Call only when the pool is full.
parslot() {
   local pid
   wait -p pid -n "${running[@]}"
   for slot in "${!running[@]}"; do
      [[ "${running[$slot]}" == "$pid" ]] && break
   done
   unset 'running[slot]'
}

check-render-host() {
   local output="$1"
   local h="$2"
   local host="$3"
   local line
   local stamp
   stamp="$(date -d "@$date" "+%Y/%m/%d %H:%M:%S")"

   $output "$h" "$host ($stamp)"
   unset p1 p2
   test "${#updates_avail[*]}" -gt 0 && local p1="${#updates_avail[*]} updates"
   test "${#updates_hold[*]}" -gt 0 -a "$reporthold" != "off" && local p2="${#updates_hold[*]} hold"
   if [[ -n "$p1" && -n "$p2" ]]; then
      $output foldstart "$p1/$p2"
   else
      $output foldstart "$p1$p2"
   fi
   $output t_head Package "Current version" "New version" Source
   if [[ "$reporthold" != "off" ]]; then
      for pkg in "${updates_hold[@]}"; do
         $output t_line "$pkg (on hold)" "${updates_curver[$pkg]}" "${updates_newver[$pkg]}" "${updates_newversrc[$pkg]}"
      done
   fi
   for pkg in "${updates_avail[@]}"; do
      $output t_line "$pkg" "${updates_curver[$pkg]}" "${updates_newver[$pkg]}" "${updates_newversrc[$pkg]}"
   done
   $output t_end
   $output foldend
}

check-report-hosts() {
   local src="$1"

   unset host date ctname ctid updates_avail updates_hold updates_curver updates_newver updates_newversrc
   . "$src"

   test "$date" -lt "$reportafter" && return 1

   test "$reporthold" = "off" -a "${#updates_avail[*]}" -eq 0 && return 1
   frmt new checkrender "${outputformat}" -b
   if [[ "$ctname" == "" ]]; then
      check-render-host checkrender h2 "$host"
   else
      check-render-host checkrender h3 "$ctname ($ctid@$host)"
   fi
   checkrender del
   return 0
}

check-report() {
   local systems
   local cache="$CACHE/updates"

   [[ "$report" == "" ]] && { wiki connect || { printf '%s\n' "Unable to connect to wiki ($(wiki error))."; exit 1; } }
   reportoutput=$(tmpfile)
   frmt new checkreport "${outputformat}" > "$reportoutput"
   checkreport print "Generated on: $(date "+%Y/%m/%d  %H:%M:%S") (results after $(date -d "@$reportafter" "+%Y/%m/%d  %H:%M:%S"))" >> "$reportoutput"
   for section in $( printf "%s\n" "${!hostsectionnames[@]}" | sort ); do
      unset systems
      test "${#hostlists[@]}" -gt 0 && test "${hostlists[$section]}" != "" && systems=( ${hostlists[$section]} )
      test "${#hostcmds[@]}" -gt 0  && test "${hostcmds[$section]}" != "" && systems=( $( bash -c "${hostcmds[$section]}" ) )
      makesection check-report-hosts "$cache" "${hostsectionnames[$section]}" "${systems[@]}" >> "$reportoutput"
   done
   checkreport del >> "$reportoutput"
   [[ "$report" == "" ]] && { wiki save "${main[checkreport]}" - < "$reportoutput" || { printf '%s\n' "Unable to save to wiki ($(wiki error))."; exit 1; } }
   [[ "$report" != "" ]] && cat "$reportoutput"
   rm -f "$reportoutput"
}

# Print hosts (and/or containers) that have pending updates, based on cached
# check results in $CACHE/updates. Honours $hostonly/$ctonly (set from -H/-C) and
# $reportafter. With no hosts given, scans every host directory in the cache.
check-list() {
   local cache="$CACHE/updates"
   local h ct src
   local hostsonly=0 ctsonly=0
   local _ng
   [[ "$hostonly" == "1" ]] && hostsonly=1
   [[ "$ctonly" == "1" ]] && ctsonly=1

   _ng=$(shopt -p nullglob)
   shopt -s nullglob

   if test "${#hosts[*]}" -eq 0; then
      hosts=()
      for d in "$cache"/*/; do
         hosts+=( "${d%/}" )
      done
      hosts=( "${hosts[@]#$cache/}" )
   fi

   for h in "${hosts[@]}"; do
      if test "$ctsonly" -eq 0 && test -f "$cache/$h/$h"; then
         src="$cache/$h/$h"
         unset host date ctname ctid updates_avail updates_hold updates_curver updates_newver updates_newversrc
         . "$src"
         if test "${date:-0}" -ge "$reportafter" && { test "${#updates_avail[*]}" -gt 0 || test "${#updates_hold[*]}" -gt 0; }; then
            printf '%s\n' "$host"
         fi
      fi
      if test "$hostsonly" -eq 0; then
         for src in "$cache/$h/"*; do
            [[ -e "$src" ]] || continue
            ct=${src##*/}
            [[ "$ct" == "$h" ]] && continue
            unset host date ctname ctid updates_avail updates_hold updates_curver updates_newver updates_newversrc
            . "$src"
            if test "${date:-0}" -ge "$reportafter" && { test "${#updates_avail[*]}" -gt 0 || test "${#updates_hold[*]}" -gt 0; }; then
               printf '%s\n' "$ctname ($ctid@$host)"
            fi
         done
      fi
   done

   eval "$_ng"
}

host-save() {
   local output="$1"; shift
   local date
   date=$(date "+%s")

   {
      if [[ "${ret:-}" == "" ]]; then
         declare -p host date | sed 's/ --/ -g/'
      else
         declare -p host date ret | sed 's/ --/ -g/'
      fi
      [[ "$ctname" != "" ]] && declare -p ctname | sed 's/ --/ -g/'
      [[ "$ctid" != "" ]] && declare -p ctid | sed 's/ --/ -g/'
      declare -p "$@" | sed 's/ -[aA]/&g/'
   } > "$output"
}

check-save() {
   host-save "$@" updates_avail updates_hold updates_curver updates_newver updates_newversrc
}

check-container() {
   local ctname="${containers[$ctid]}"

   in_array "$ctid" "${ctexcl[@]}" && return
   test "${#ctincl[*]}" -gt 0 && ! in_array "$ctid" "${ctincl[@]}" && return
   verifycache "$cache" "$host" "$ctname" || return
   rm -f "$cache/$host/$ctname"
   updates check "${opts[@]}" "$host" "$ctid" || { println "Error on container $ctname ($(updates error))" >&2; return; }
   if test "${#updates_avail[*]}" -gt 0 -o "${#updates_hold[*]}" -gt 0; then
      check-save "$cache/$host/$ctname"
   fi
}

check-host() {
   local line="$1"
   local dstfile
   unset ctname ctid
   checkhost=1
   local jobs="$PARCT"
   declare -a running
   declare -a runningct
   local slot=0

   in_array "$host" "${hostexcl[@]}" && checkhost=0

   [[ "${host//./}" == "$host" ]] && { println "Skipping host ${host}, does not look like fqdn."; return; }
   updates is-container "$host" && { println "Skipping host ${host}, is a container."; return; }
   test "$QUIET" -eq 0 && println "$done/$num $host" >&2

   if test "$checkhost" -eq 1 && verifycache "$cache" "$host"; then
      rm -f "$cache/$host/$host"
      updates check "${opts[@]}" "$host" || println "Error on $host $(updates error)" >&2
      if test "${#updates_avail[*]}" -gt 0 -o "${#updates_hold[*]}" -gt 0; then
         check-save "$cache/$host/$host"
      fi
   fi

   [[ "${ctexcl[0]}" == "all" ]] && { println "$done/$num done"; return; }
   updates container-list "$host"
   test "${#containers[*]}" -eq 0 && { println "$done/$num done"; return; }
   ctdone=0
   for ctid in "${!containers[@]}"; do
      check-container &
      running[slot]=$!
      runningct[slot]=$ctid
      ctdone=$(( ctdone + 1 ))
      test "$QUIET" -eq 0 && println "$done/$num $host, ct: ${runningct[*]// /,} ($ctdone/${#containers[@]})" >&2
      if test "${#running[*]}" -eq $jobs; then
         parslot
         unset 'runningct[slot]'
      else
         slot=$(( slot + 1 ))
      fi
   done
   wait
   println "$done/$num done"
}

check() {
   local done=0
   local num="$#"
   local cache="$CACHE/updates"
   local opts
   declare -a opts
   local jobs="$PARHOST"
   declare -a running
   local slot=0

   test "$UPDATE" -eq 1 && opts+=( "-u" )
   test "$#" -lt "$jobs" && jobs="$#"

   progress_reserve "$jobs"
   for host in "$@"; do
      done=$(( done + 1 ))
      check-host $(( jobs - slot )) &
      running[slot]=$!
      if test "${#running[*]}" -eq $jobs; then
         parslot
      else
         slot=$(( slot + 1 ))
      fi
   done
   wait
}

upgradehost-save() {
   host-save "$@" updates_output
}

upgrade-container() {
   local ctname="${containers[$ctid]}"
   local dstfile ret

   verifycache "$cache" "$host" "$ctname" || return
   updates check "$host" "$ctid" || { println "Error on container $ctname ($(updates error))" >&2; return; }
   dstfile="$cache/$host/$ctname"
   if test "${#updates_avail[*]}" -gt 0; then
      updates upgrade "${opts[@]}" "$host" "$ctid"
      ret=$?
      upgradehost-save "$dstfile"
   else
      [[ -e "$dstfile" ]] && touch "$dstfile"
   fi
}

upgrade-host() {
   local line="$1"
   local jobs="$PARCT"
   local checkhost dstfile ret
   declare -a running runningct
   unset ctname ctid
   local slot=0
   checkhost=1

   in_array "$host" "${hostexcl[@]}" && checkhost=0
   in_array "$host" "${blacklist[@]}" && [[ "$NOCTBL" != 1 ]] && return
   in_array "$host" "${blacklist[@]}" && checkhost=0
   [[ "${host//./}" == "$host" ]] && { println "Skipping host ${host}, does not look like fqdn.\n"; return; }
   updates is-container "$host" && { println "Skipping host ${host}, is a container.\n"; return; }
   test "$QUIET" -eq 0 && println "$done/$num $host" >&2

   if test "$checkhost" -eq 1 && verifycache "$cache" "$host"; then
      updates check "$host"
      dstfile="$cache/$host/$host"
      if test "${#updates_avail[*]}" -gt 0; then
         updates upgrade "${opts[@]}" "$host"
         ret=$?
         upgradehost-save "$dstfile"
      else
         [[ -e "$dstfile" ]] && touch "$dstfile"
      fi
   fi

   [[ "${ctexcl[0]}" == "all" ]] && { println "$done/$num done"; return; }
   updates container-list "$host"
   test "${#containers[*]}" -eq 0 && { println "$done/$num done"; return; }
   ctdone=0
   for ctid in "${!containers[@]}"; do
      local ctname="${containers[$ctid]}"
      in_array "$ctid" "${ctexcl[@]}" && continue
      test "${#ctincl[*]}" -gt 0 && ! in_array "$ctid" "${ctincl[@]}" && continue
      in_array "$ctname" "${blacklist[@]}" && continue

      upgrade-container &
      running[slot]=$!
      runningct[slot]=$ctid
      ctdone=$(( ctdone + 1 ))
      test "$QUIET" -eq 0 && println "$done/$num $host, ct: ${runningct[*]// /,} ($ctdone/${#containers[@]})" >&2
      if test "${#running[*]}" -eq $jobs; then
         parslot
         unset 'runningct[slot]'
      else
         slot=$(( slot + 1 ))
      fi
   done
   wait
   println "$done/$num done"
}

upgrade() {
   local done=0
   local num="$#"
   local cache="$CACHE/upgrades"
   local opts
   declare -a opts
   local jobs="$PARHOST"
   declare -a running
   local slot=0

   test "$DRYRUN" -eq 1 && opts+=( "-s" )
   test "$DOWNLOAD" -eq 1 && opts+=( "-d" )

   test "$#" -lt "$jobs" && jobs="$#"

   progress_reserve "$jobs"
   for host in "$@"; do
      done=$(( done + 1 ))
      upgrade-host $(( jobs - slot )) &
      running[slot]=$!
      if test "${#running[*]}" -eq $jobs; then
         parslot
      else
         slot=$(( slot + 1 ))
      fi
   done
   wait
}

upgrade-render-host() {
   local output="$1"
   local h="$2"
   local host="$3"
   local ret="$4"
   local line
   local stamp
   stamp="$(date -d "@$date" "+%Y/%m/%d %H:%M:%S")"

   local state="ok"
   [[ " ${updates_output[*]} " =~ " Configuration file " ]] && state="CONFIG CHANGE"
   [[ "$ret" != "0" ]] && state="FAIL"
   $output "$h" "$host ($state) ($stamp)"
   [[ "$reportskip" == "1" ]] && return
   $output foldstart "Output ${#updates_output[*]} lines"
   for line in "${updates_output[@]}"; do
      $output pre "$line"
   done
   $output foldend
}

upgrade-report-hosts() {
   local src="$1"

   unset host date ret ctname ctid updates_output
   . "$src"

   test "$date" -lt "$reportafter" && return 1
   [[ "$reporterr" == "1" && "$ret" == "0" ]] && return 1

   frmt new upgraderender "${outputformat}" -b
   if [[ "$ctname" == "" ]]; then
      upgrade-render-host upgraderender h2 "$host" "$ret"
   else
      upgrade-render-host upgraderender h3 "$ctname ($ctid@$host)" "$ret"
   fi
   upgraderender del
}

upgrade-report() {
   local systems
   local cache="$CACHE/upgrades"

   [[ "$report" == "" ]] && { wiki connect || { printf '%s\n' "Unable to connect to wiki ($(wiki error))."; exit 1; } }
   reportoutput=$(tmpfile)
   frmt new upgradereport "${outputformat}" > "$reportoutput"
   upgradereport print "Generated on: $(date "+%Y/%m/%d  %H:%M:%S") (results after $(date -d "@$reportafter" "+%Y/%m/%d  %H:%M:%S"))" >> "$reportoutput"
   for section in $( printf "%s\n" "${!hostsectionnames[@]}" | sort ); do
      unset systems
      test "${#hostlists[@]}" -gt 0 && test "${hostlists[$section]}" != "" && systems=( ${hostlists[$section]} )
      test "${#hostcmds[@]}" -gt 0  && test "${hostcmds[$section]}" != "" && systems=( $( bash -c "${hostcmds[$section]}" ) )
      makesection upgrade-report-hosts "$cache" "${hostsectionnames[$section]}" "${systems[@]}" >> "$reportoutput"
   done
   upgradereport del >> "$reportoutput"
   [[ "$report" == "" ]] && { wiki save "${main[upgradereport]}" - < "$reportoutput" || { printf '%s\n' "Unable to save to wiki ($(wiki error))."; exit 1; } }
   [[ "$report" != "" ]] && cat "$reportoutput"
   rm -f "$reportoutput"
}

snapshot-run() {
   local subcmd="$1"; shift
   local cache="$1"
   local host="$2"
   local ctid="$3"

   [[ "$ctid" == "" ]] && return
   rm -f "$cache"
   updates "$subcmd" "$host" "$ctid" "${snapfilter[@]}"
   if test "$?" -eq 0 -a "${#snapshots[*]}" -gt 0; then
      local date
      date=$(date "+%s")
      local ctname="${containers[$ctid]}"
      {
         declare -p host date | sed 's/ --/ -g/'
         [[ "$ctname" != "" ]] && declare -p ctname | sed 's/ --/ -g/'
         [[ "$ctid" != "" ]] && declare -p ctid | sed 's/ --/ -g/'
         declare -p snapshots | sed 's/ -[aA]/&g/'
      } > "$cache"
   else
      return 1
   fi
   return 0
}

snapshot-rm() { snapshot-run snapshot-rm "$@"; }
snapshot-list() { snapshot-run snapshot-list "$@"; }

snapshot-report() {
   local cache="$1"
   frmt new snaprep "${report}"
   for host in "${hosts[@]}"; do
      unset cts
      cts=()
      for f in "$CACHE/$cache/$host/"*; do
         [[ -e "$f" ]] || continue
         f=${f##*/}
         [[ "$f" != "$host" ]] && cts+=( "$f" )
      done
      if test "${#cts[*]}" -gt 0; then
         snaprep h1 "$host"
         snaprep t_head "Container" "Snapshot(s)"
         for ct in "${cts[@]}"; do
            unset date ctname ctid snapshots
            . "$CACHE/$cache/$host/$ct"
            snaprep t_line "$ct" "${snapshots[*]}"
         done
         snaprep t_end
      fi
   done
   snaprep del
}

# Decide how parallel progress is shown. Controlled by the UPDATES_PROGRESS env var:
#   terminal  - in-place cursor updates (default; needs a real terminal)
#   iframe    - streaming live HTML/JS dashboard (use with script-server output_format
#               html_iframe; gives a per-host live progress view in the browser)
#   plain     - one simple line per progress event, no cursor codes
#   auto      - terminal when stderr is a TTY, plain otherwise
progress_mode() {
   local m="${UPDATES_PROGRESS:-auto}"
   case "$m" in
      terminal|iframe|plain) printf '%s' "$m" ;;
      auto) [ -t 2 ] && printf terminal || printf plain ;;
      *) printf terminal ;;
   esac
}

# Escape a string so it is safe to embed inside a JavaScript single-quoted string
# (also neutralises </script> and other HTML-breaking sequences).
esc_js() {
   local s="$1"
   s="${s//\\/\\\\}"
   s="${s//\'/\\x27}"
   s="${s//</\\x3c}"
   s="${s//>/\\x3e}"
   s="${s//$'\n'/ }"
   s="${s//$'\r'/ }"
   printf '%s' "$s"
}

# Emit the (once) HTML scaffold for the iframe live dashboard. Idempotent.
progress_scaffold() {
   [[ "${_UPD_SCAFFOLD:-0}" == 1 ]] && return
   _UPD_SCAFFOLD=1
   cat >&2 <<'HTML'
<!DOCTYPE html><html lang="en"><head><meta charset="utf-8">
<style>
#upd{font-family:ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;font-size:13px;line-height:1.45}
.upd-row{display:flex;align-items:center;gap:.5em;padding:2px 6px;margin:1px 0;border-left:3px solid #bbb;background:#fafafa}
.upd-row.done{opacity:.5;background:#eee;border-left-color:#3a3}
.upd-host{font-weight:600;min-width:18em;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.upd-msg{flex:1;white-space:pre}
.upd-spin{flex:0 0 12px;width:12px;height:12px;border:2px solid #ccc;border-top-color:#444;border-radius:50%;animation:updsp .8s linear infinite}
.done .upd-spin{display:none}
@keyframes updsp{to{transform:rotate(360deg)}}
</style></head><body>
<div id="upd"></div>
<script>
(function(){
 var rows={};
 window.upd_set=function(host,msg){
  var r=rows[host];
  if(!r){
   r=document.createElement('div');r.className='upd-row';
   var sp=document.createElement('span');sp.className='upd-spin';r.appendChild(sp);
   var h=document.createElement('span');h.className='upd-host';h.textContent=host;r.appendChild(h);
   var m=document.createElement('span');m.className='upd-msg';r.appendChild(m);
   document.getElementById('upd').appendChild(r);
   rows[host]={el:r,msg:m};
  }
  rows[host].msg.textContent=msg;
 };
 window.upd_done=function(host){ var r=rows[host]; if(r){r.el.classList.add('done');} };
})();
</script>
HTML
}

# Reserve the progress display at the start of a parallel run. $1 is the number of
# parallel slots (only meaningful for terminal mode).
progress_reserve() {
   test "$QUIET" -eq 0 || return
   case "$PROMODE" in
      terminal) printf '%.0s\n' $(seq 1 "$1") ;;
      iframe) progress_scaffold ;;
      plain) ;;
   esac
}

# Tear down the reserved progress display at the end of a parallel run.
progress_finish() {
   test "$QUIET" -eq 0 || return
   case "$PROMODE" in
      terminal) local i; for (( i=0; i<$1; i++ )); do printf "\e[1A\e[K\r"; done ;;
      *) ;;
   esac
}

# Print a progress line for the current host. In terminal mode it is drawn in place at
# the caller's screen row ($line); the caller declares $line and $host locally and each
# parallel host/container runs in its own subshell. In iframe mode each call streams one
# atomic <script> update to the live dashboard; in plain mode it just prints the line.
println() {
   test "$QUIET" -eq 0 || return
   case "$PROMODE" in
      terminal) printf "\e[%dA\e[K%s\e[%dB\r" "$line" "$1" "$line" ;;
      plain) printf '%s\n' "$1" >&2 ;;
      iframe)
         local _h _m
         _h="$(esc_js "$host")"
         _m="$(esc_js "$1")"
         if [[ "$1" == *" done" ]]; then
            printf "<script>window.upd_set('%s','%s');window.upd_done('%s');</script>\n" "$_h" "$_m" "$_h" >&2
         else
            printf "<script>window.upd_set('%s','%s');</script>\n" "$_h" "$_m" >&2
         fi
         ;;
   esac
}

runcontainer() {
   local action="$1"; shift
   local ctname="${containers[$ctid]}"
   local cache="$cache/$ctname"

   "$action" "$cache" "$host" "$ctid"
}

runhost() {
   local action="$1"; shift
   local line="$1"; shift
   local jobs="$PARCT"
   local checkhost dstfile
   declare -a running runningct
   unset ctname ctid
   local slot=0
   local checkhost=1
   local cache="$cache/$host"

   [[ ! -d "$cache" ]] && mkdir -p "$cache"

   in_array "$host" "${hostexcl[@]}" && checkhost=0
   in_array "$host" "${blacklist[@]}" && [[ "$NOCTBL" != 1 ]] && return
   in_array "$host" "${blacklist[@]}" && checkhost=0
   [[ "${host//./}" == "$host" ]] && { println "Skipping host ${host}, does not look like fqdn.\n"; return; }
   updates is-container "$host" && { println "Skipping host ${host}, is a container.\n"; return; }
   println "$done/$num $host" >&2

   test "$checkhost" -eq 1 && $action "$cache/$host/$host" "$host"

   [[ "${ctexcl[0]}" == "all" ]] && { println "$done/$num done"; return; }
   updates container-list "$host"
   test "${#containers[*]}" -eq 0 && { println "$done/$num done"; return; }
   ctdone=0
   for ctid in "${!containers[@]}"; do
      local ctname="${containers[$ctid]}"
      in_array "$ctid" "${ctexcl[@]}" && continue
      test "${#ctincl[*]}" -gt 0 && ! in_array "$ctid" "${ctincl[@]}" && continue
      in_array "$ctname" "${blacklist[@]}" && continue

      runcontainer "$action" &
      running[slot]=$!
      runningct[slot]=$ctid
      ctdone=$(( ctdone + 1 ))
      println "$done/$num $host, ct: ${runningct[*]// /,} ($ctdone/${#containers[@]})" >&2
      if test "${#running[*]}" -eq $jobs; then
         parslot
         unset 'runningct[slot]'
      else
         slot=$(( slot + 1 ))
      fi
   done
   wait
   println "$done/$num done"
}

# runaction <action> <cache dir name>
runaction() {
   local done=0
   local jobs="$PARHOST"
   declare -a running
   local slot=0
   local newslot=0
   local maxslot=0
   local action="$1"; shift
   local cache="$CACHE/$1"; shift
   num=$#

   test "$#" -lt "$jobs" && jobs="$#"
   [[ ! -d "$cache" ]] && mkdir -p "$cache"

   progress_reserve "$jobs"
   for host in "$@"; do
      done=$(( done + 1 ))
      newslot=$(( jobs - slot ))
      runhost "$action" "$newslot" &
      test "$newslot" -gt "$maxslot" && maxslot="$newslot"
      running[slot]=$!
      if test "${#running[*]}" -eq $jobs; then
         parslot
      else
         slot=$(( slot + 1 ))
      fi
   done
   wait
   progress_finish "$maxslot"
}

