readconfig() {
   local var val section line lead

   CFG=$(realpath "$CFG")
   [[ ! -e "$CFG" ]] && { printf '%s\n' "Config file $CFG does not exist."; exit 1; }
   test "$(stat -c %a "$CFG")" -gt 600 && { printf '%s\n' "Unsafe permissions on config file $CFG."; exit 1; }

   # Parse the .ini-style config: [sections] and key=value lines. Values may
   # contain spaces and `=` (everything after the first `=` is kept verbatim,
   # with surrounding whitespace trimmed). Blank lines and comments (column-0
   # or indented `#`) are ignored. `read -r` preserves literal backslashes.
   while IFS= read -r line || [[ -n "$line" ]]; do
      lead="${line#"${line%%[![:space:]]*}"}"
      [[ -z "$lead" || "$lead" == \#* ]] && continue
      IFS='= ' read -r var val <<< "$lead"
      if [[ $var == \[*\] ]]; then
         section="${var:1:-1}"
      elif [[ $val && -n "$section" ]]; then
         declare -g -A "${section}[$var]=$val"
      fi
   done < "$CFG"
   [[ "${main[wikiprofile]}" == "" ]] && { printf '%s\n' "wikiprofile not defined in config file."; exit 1; }
   [[ -z "${main[allhostslist]}" && -z "${main[allhostscmd]}" ]] && { printf '%s\n' "allhostslist and allhostscmd not defined in config file."; exit 1; }
   [[ -n "${main[allhostslist]}" && -n "${main[allhostscmd]}" ]] && { printf '%s\n' "allhostslist and allhostscmd both defined in config file."; exit 1; }
   [[ "${main[checkreport]}" == "" ]] && main[checkreport]="Updatereport"
   [[ "${main[upgradereport]}" == "" ]] && main[upgradereport]="Upgradereport"
   [[ "${main[allhostscmd]}" != "" ]] && allhosts=( $( bash -c "${main[allhostscmd]}" ) )
   [[ "${main[allhostslist]}" != "" ]] && allhosts=( ${main[allhostslist]} )
   [[ "${main[upgradeblacklistcmd]}" != "" ]] && blacklist=( $( bash -c "${main[upgradeblacklistcmd]}" ) )
   [[ "${main[upgradeblacklist]}" != "" ]] && blacklist=( ${main[upgradeblacklist]} )
}

arguments() {
   while getopts :hqc: opt; do
     case $opt in
     h) usage ;;
     q) QUIET=1 ;;
     c) CFG=$OPTARG ;;
     \?) printf '%s\n' "Unknown option: -$OPTARG"; usage ;;
     :) printf '%s\n' "Option -$OPTARG requires argument"; usage ;;
     esac
   done
   shift $((OPTIND-1))

   readconfig

   action="$1"; shift
   OPTIND=1

   case "$action" in
   "list")
      main[list]=all
      while getopts :hab opt; do
         case $opt in
         h) usage $action;;
         a) main[list]=all;;
         b) main[list]=black;;
         \?) printf '%s\n' "Unknown option: -$OPTARG"; usage $action;;
         :) printf '%s\n' "Option -$OPTARG requires argument"; usage $action;;
         esac
      done
      shift $((OPTIND-1))
      test $# -ne 0 && hosts=( "$@" )
   ;;
   "check")
      while getopts :hfpui:e:E: opt; do
         case $opt in
         h) usage $action ;;
         f) FORCE=1 ;;
         u) UPDATE=1 ;;
         i) ctincl=( ${OPTARG//,/ } ) ;;
         p) PARALLEL=1 ;;
         e) ctexcl=( ${OPTARG//,/ } ) ;;
         E) hostexcl=( ${OPTARG//,/ } ) ;;
         \?) printf '%s\n' "Unknown option: -$OPTARG"; usage $action ;;
         :) printf '%s\n' "Option -$OPTARG requires argument"; usage $action ;;
         esac
      done
      shift $((OPTIND-1))
      test $# -ne 0 && hosts=( "$@" )
      if test "${#hosts[*]}" -eq 0; then
         hosts=( "${allhosts[@]}" )
      else
         for host in "${hosts[@]}"; do
            ! in_array "$host" "${allhosts[@]}" && { printf '%s\n' "Host ${host} not part of all hosts."; exit 1; }
         done
      fi
   ;;
   "check-list")
      while getopts :hHC opt; do
         case $opt in
         h) usage $action;;
         H) hostonly=1;;
         C) ctonly=1;;
         \?) printf '%s\n' "Unknown option: -$OPTARG"; usage $action;;
         :) printf '%s\n' "Option -$OPTARG requires argument"; usage $action;;
         esac
      done
      shift $((OPTIND-1))
      test $# -ne 0 && hosts=( "$@" )
   ;;
   "check-report")
      while getopts :hHp:awA: opt; do
         case $opt in
         h) usage $action;;
         H) reporthold=off;;
         p) main[checkreport]="$OPTARG" ;;
         w) report=html;;
         a) report=ascii;;
         A) reportafter=$( date -d "${OPTARG}" "+%s" );;
         \?) printf '%s\n' "Unknown option: -$OPTARG"; usage $action;;
         :) printf '%s\n' "Option -$OPTARG requires argument"; usage $action;;
         esac
      done
      shift $((OPTIND-1))
   ;;
   "upgrade")
      while getopts :hcpfdsi:e:E: opt; do
         case $opt in
         h) usage $action ;;
         c) NOCTBL=1 ;;
         f) FORCE=1 ;;
         p) PARALLEL=1 ;;
         s) DRYRUN=1 ;;
         d) DOWNLOAD=1 ;;
         i) ctincl=( ${OPTARG//,/ } ) ;;
         e) ctexcl=( ${OPTARG//,/ } ) ;;
         E) hostexcl=( ${OPTARG//,/ } ) ;;
         \?) printf '%s\n' "Unknown option: -$OPTARG"; usage $action ;;
         :) printf '%s\n' "Option -$OPTARG requires argument"; usage $action ;;
         esac
      done
      shift $((OPTIND-1))
      test $# -ne 0 && hosts=( "$@" )
      if test "${#hosts[*]}" -eq 0; then
         hosts=( "${allhosts[@]}" )
      else
         for host in "${hosts[@]}"; do
            ! in_array "$host" "${allhosts[@]}" && { printf '%s\n' "Host ${host} not part of all hosts."; exit 1; }
         done
      fi
   ;;
   "upgrade-report")
      while getopts :hep:aswA: opt; do
         case $opt in
         h) usage $action;;
         e) reporterr=1;;
         p) main[upgradereport]="$OPTARG" ;;
         w) report=html;;
         a) report=ascii;;
         s) reportskip=1;;
         A) reportafter=$( date -d "${OPTARG}" "+%s" );;
         \?) printf '%s\n' "Unknown option: -$OPTARG"; usage $action;;
         :) printf '%s\n' "Option -$OPTARG requires argument"; usage $action;;
         esac
      done
      shift $((OPTIND-1))
   ;;
   "snapshot-list")
      report=ascii
      while getopts :hpwf: opt; do
         case $opt in
         f) snapfilter=( "-f" "$OPTARG" ) ;;
         w) report=html;;
         p) PARALLEL=1 ;;
         h) usage $action;;
         \?) printf '%s\n' "Unknown option: -$OPTARG"; usage $action;;
         :) printf '%s\n' "Option -$OPTARG requires argument"; usage $action;;
         esac
      done
      shift $((OPTIND-1))
      test $# -ne 0 && hosts=( "$@" )
      if test "${#hosts[*]}" -eq 0; then
         hosts=( "${allhosts[@]}" )
      else
         for host in "${hosts[@]}"; do
            ! in_array "$host" "${allhosts[@]}" && { printf '%s\n' "Host ${host} not part of all hosts."; exit 1; }
         done
      fi
   ;;
   "snapshot-rm")
      report=ascii
      while getopts :hpwf: opt; do
         case $opt in
         f) snapfilter=( "-f" "$OPTARG" ) ;;
         w) report=html;;
         p) PARALLEL=1 ;;
         h) usage $action;;
         \?) printf '%s\n' "Unknown option: -$OPTARG"; usage $action;;
         :) printf '%s\n' "Option -$OPTARG requires argument"; usage $action;;
         esac
      done
      shift $((OPTIND-1))
      test $# -ne 0 && hosts=( "$@" )
      if test "${#hosts[*]}" -eq 0; then
         hosts=( "${allhosts[@]}" )
      else
         for host in "${hosts[@]}"; do
            ! in_array "$host" "${allhosts[@]}" && { printf '%s\n' "Host ${host} not part of all hosts."; exit 1; }
         done
      fi
   ;;
   *) printf '%s\n' "Unknown action $action"; usage ;;
   esac
   if [[ "$PARALLEL" == "1" ]]; then
      [[ "${main[parallelhost]}" != "" ]] && PARHOST=${main[parallelhost]} || PARHOST=4
      [[ "${main[parallelct]}" != "" ]] && PARCT=${main[parallelct]} || PARCT=2
   fi
}

list() {
   case "${main[list]}" in
   all)
      printf "%s\n" "${allhosts[@]}"
   ;;
   black)
      printf "%s\n" "${blacklist[@]}"
   ;;
   esac
}

main() {
   CACHE="$HOME/.updates.cache"
   MAXCACHEAGE=6000
   FORCE=0
   DRYRUN=0
   DOWNLOAD=0
   UPDATE=0
   QUIET=0
   reportafter=$( date -d "today 0:0:0" "+%s" )
   PARHOST=1
   PARCT=1
   CFG=~/.updates.ini

   [[ "$UPDATESCFG" != "" ]] && CFG="$UPDATESCFG"

   [[ ! -d "$CACHE" ]] && mkdir "$CACHE"

   arguments "$@"

   PROMODE="$(progress_mode)"

   wiki profile "${main[wikiprofile]}" || { printf '%s\n' "Unable to open wiki ($(wiki error))"; exit 1; }
   outputformat=$( wiki type )
   [[ "$report" != "" ]] && outputformat="$report"
   case "$action" in
   "list")
      list
   ;;
   "check")
      check "${hosts[@]}"
   ;;
   "check-list")
      check-list
   ;;
   "check-report")
      check-report
   ;;
   "upgrade")
      upgrade "${hosts[@]}"
   ;;
   "upgrade-report")
      upgrade-report
   ;;
   "snapshot-list")
      cache="snapshots"
      runaction "snapshot-list" "$cache" "${hosts[@]}"
      snapshot-report "$cache"
   ;;
   "snapshot-rm")
      cache="snapshots"
      runaction "snapshot-rm" "$cache" "${hosts[@]}"
      snapshot-report "$cache"
   ;;
   *) printf '%s\n' "Unknown action $action"; usage ;;
   esac
}

main "$@"
